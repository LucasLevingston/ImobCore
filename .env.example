# ── Portas ──────────────────────────────────────────────
AUTH_SERVICE_PORT=3001
PRODUCTS_SERVICE_PORT=3002
AUTH_FRONTEND_PORT=3000
PRODUCTS_FRONTEND_PORT=3003

# ── Bancos (um por serviço — nunca compartilhados) ────────
AUTH_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/auth_db?schema=public"
PRODUCTS_DATABASE_URL="postgresql://postgres:postgres@localhost:5434/products_db?schema=public"

# ── JWT (segredo compartilhado só p/ verificação de assinatura entre serviços) ──
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_ACCESS_TOKEN_EXPIRES_IN="15m"
JWT_REFRESH_TOKEN_EXPIRES_IN="7d"

# ── Bcrypt ─────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10

# ── URLs públicas (frontends) ──────────────────────────
NEXT_PUBLIC_AUTH_SERVICE_URL="http://localhost:3001"
NEXT_PUBLIC_PRODUCTS_SERVICE_URL="http://localhost:3002"
NEXT_PUBLIC_AUTH_FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_PRODUCTS_FRONTEND_URL="http://localhost:3003"
