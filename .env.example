# ── Portas ──────────────────────────────────────────────
AUTH_SERVICE_PORT=3001
PROPERTIES_SERVICE_PORT=3002
AUTH_FRONTEND_PORT=3000
PROPERTIES_FRONTEND_PORT=3003
API_GATEWAY_PORT=3004
PORTAL_PORT=3005

# ── Bancos (um por serviço — nunca compartilhados) ────────
# Prisma 7: connection_limit não é mais um param de query da URL — o pool é
# controlado pelo driver adapter (max: 5, hardcoded em cada client.ts), já
# que o Prisma não parseia mais a URL diretamente (motor Rust removido).
AUTH_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/auth_db?schema=public"
PROPERTIES_DATABASE_URL="postgresql://postgres:postgres@localhost:5434/properties_db?schema=public"

# ── JWT (segredo compartilhado só p/ verificação de assinatura entre serviços) ──
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_ACCESS_TOKEN_EXPIRES_IN="15m"
JWT_REFRESH_TOKEN_EXPIRES_IN="7d"

# ── Bcrypt ─────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10

# ── URLs internas (usadas só pelo api-gateway p/ fazer proxy — nunca por frontend) ──
AUTH_SERVICE_URL="http://localhost:3001"
PROPERTIES_SERVICE_URL="http://localhost:3002"

# ── api-gateway (CORS + rate limit + guard de CSRF centralizados aqui — ver docs/ARCHITECTURE.md seção 04a) ──
# O Portal (:3005) chama /api/auth/me e /api/auth/logout direto no gateway —
# sem a origem dele aqui, o guard de CSRF da Fase 7 (origin-guard.ts) devolve
# 403 pra essas chamadas mesmo em dev.
CORS_ORIGIN="http://localhost:3000,http://localhost:3003,http://localhost:3005"
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW="1 minute"

# ── URLs públicas (frontends) ──────────────────────────
# Toda chamada de API do frontend vai pro gateway — nunca direto num service (ver docs/ARCHITECTURE.md seção 04a)
NEXT_PUBLIC_API_GATEWAY_URL="http://localhost:3004"
NEXT_PUBLIC_AUTH_FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_PROPERTIES_FRONTEND_URL="http://localhost:3003"
NEXT_PUBLIC_PORTAL_FRONTEND_URL="http://localhost:3005"
