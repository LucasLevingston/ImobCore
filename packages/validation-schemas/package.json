{
  "name": "@microfrontends/validation-schemas",
  "version": "0.1.0",
  "private": true,
  "description": "Schemas Zod compartilhados (regras de negócio puras) entre properties-frontend e properties-service — elimina a duplicação de enums/limites/mensagens de validação entre client e server",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
