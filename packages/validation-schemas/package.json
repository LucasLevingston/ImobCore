    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10",
    "zod": "^3.23.8"
  }
}
