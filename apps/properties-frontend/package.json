{
  "name": "properties-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Micro Frontend de imóveis (dashboard, listagem, cadastro, edição, exclusão, busca, filtros, paginação, detalhes) — Next.js App Router",
  "scripts": {
    "dev": "next dev -p 3003 --webpack",
    "build": "next build --webpack",
    "start": "next start -p 3003",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "generate:api": "orval --config orval.config.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@microfrontends/ui": "*",
    "@microfrontends/validation-schemas": "*",
    "@tanstack/react-query": "^5.59.20",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@microfrontends/module-federation-utils": "*",
    "@module-federation/enhanced": "^2.8.0",
    "@tailwindcss/postcss": "^4.3.2",
    "orval": "^8.22.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "msw": "^2.6.4",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10",
    "webpack": "^5.108.4"
  }
}
