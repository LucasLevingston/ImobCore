{
  "name": "api-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Único ponto de entrada HTTP público — proxy + CORS + rate-limit + request-id pra auth-service e properties-service",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main/server.ts",
    "start": "tsx src/main/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/http-proxy": "^11.5.0",
    "@fastify/rate-limit": "^11.1.0",
    "fastify": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
}
